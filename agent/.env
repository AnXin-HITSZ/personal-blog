# 应用配置
APP_NAME=SuperBizAgent
DEBUG=True
HOST=0.0.0.0
PORT=8000

# DashScope 配置（仅用于 Embedding，保留不动）
DASHSCOPE_API_KEY=sk-e7b5a3f456784a4db8bd6633fc5a8760
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

# DeepSeek 配置（LLM 对话，OpenAI 兼容接口）
DEEPSEEK_API_KEY=sk-3b8125804fe84484841e12e124496014
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Qdrant 配置
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=biz

# Redis 配置（对话历史持久化）
REDIS_URL=redis://localhost:6379/0

# RAG 配置
RAG_TOP_K=3
RAG_MODEL=deepseek-chat

# RAG 重排配置（先召回后重排）
RAG_RERANK_TOP_N=15
RAG_FINAL_TOP_K=3
RAG_RERANK_MODEL=BAAI/bge-reranker-v2-m3
RAG_RERANK_MODEL_PATH=.model_cache/BAAI/bge-reranker-v2-m3

# 文档分块配置
CHUNK_MAX_SIZE=800
CHUNK_OVERLAP=100

# MCP 服务配置
# 支持的 transport 类型：stdio（本地进程）、streamable-http（HTTP 流）
# 也可以配置真实的cls mcp服务： https://cloud.tencent.com/developer/mcp/server/11710
MCP_CLS_TRANSPORT=streamable-http
MCP_CLS_URL=http://localhost:8003/mcp
MCP_MONITOR_TRANSPORT=streamable-http
MCP_MONITOR_URL=http://localhost:8004/mcp

# ─── 部署流水线配置 ───
DEPLOY_WORK_DIR=D:\Project\personal-blog
DEPLOY_DEFAULT_BRANCH=main
DEPLOY_HEALTH_CHECK_RETRIES=3
DEPLOY_HEALTH_CHECK_INTERVAL=3
# 本地环境（无 Docker nginx）直接验证 Agent 自身即可
DEPLOY_BASE_URL=http://localhost:8000
